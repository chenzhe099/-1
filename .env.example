# === 智慧农业管理系统 - 环境变量配置 ===
# 复制此文件为 .env 并根据需要修改

# MySQL
MYSQL_ROOT_PASSWORD=smartfarm123
MYSQL_DATABASE=smartfarm

# JWT
JWT_SECRET=smartfarm-jwt-secret-key-change-in-production-use-random-64-chars-minimum

# AI Service
AI_SERVICE_URL=http://ai-service:8000
MOCK_MODE=true
CONFIDENCE_THRESHOLD=0.7

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=http://minio:9000

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
